package in.ashokit.service;

import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import in.ashokit.entity.UserInfo;
import in.ashokit.repo.UserInfoRepository;

@Service
public class UserService {

	@Autowired
	private UserInfoRepository userRepo;

	public void saveUser() {

		UserInfo info = new UserInfo();
		info.setId(102);
		info.setName("John");
		info.setGender("Male");
		info.setAge(35);
		info.setCountry("USA");

		userRepo.save(info); // UPSERT (UPDATE + INSERT)

		System.out.println("User saved...");

	}

	public void getUser(Integer userId) {

		Optional<UserInfo> byId = userRepo.findById(userId);

		if (byId.isPresent()) {
			System.out.println(byId.get());
		}
	}

	public void getAllUsers() {

		Iterable<UserInfo> all = userRepo.findAll();

		all.forEach(System.out::println);

	}

}
