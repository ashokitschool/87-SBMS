package in.ashokit.service;

import java.util.Arrays;
import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Example;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Sort;
import org.springframework.stereotype.Service;

import in.ashokit.entity.UserInfo;
import in.ashokit.repo.UserInfoRepository;

@Service
public class UserService {

	@Autowired
	private UserInfoRepository userRepo;

	public void saveUser() {

		UserInfo info = new UserInfo();
		info.setId(103);
		info.setName("Steve");
		info.setGender("Male");
		info.setAge(25);
		info.setCountry("UK");

		userRepo.save(info); // UPSERT (UPDATE + INSERT) ==> Polymorphism + Abstraction

		System.out.println("User saved...");

	}

	public void saveUsers() {

		UserInfo u1 = new UserInfo();
		u1.setId(104);
		u1.setName("Ram");
		u1.setGender("Male");
		u1.setAge(25);
		u1.setCountry("India");

		UserInfo u2 = new UserInfo();
		u2.setId(105);
		u2.setName("Ching");
		u2.setGender("Fe-Male");
		u2.setAge(29);
		u2.setCountry("China");

		userRepo.saveAll(Arrays.asList(u1, u2));

		System.out.println("User saved...");

	}

	public void getUserById(Integer userId) {

		Optional<UserInfo> byId = userRepo.findById(userId);

		if (byId.isPresent()) {
			System.out.println(byId.get());
		}
	}

	public void getUsersByIds(Integer userId) {

		List<Integer> idsList = Arrays.asList(101, 102, 103);

		Iterable<UserInfo> allById = userRepo.findAllById(idsList);

		allById.forEach(System.out::println);
	}

	public void getAllUsers() {

		// Iterable<UserInfo> all = userRepo.findAll();

		List<UserInfo> all = userRepo.findAll(Sort.by("age").descending());

		all.forEach(System.out::println);

	}

	public void getUsersWithPagination() {

		Integer pageNum = 3; // we will get from UI
		Integer pageSize = 3; // it is fixed

		PageRequest pageRequest = PageRequest.of(pageNum - 1, pageSize);

		Page<UserInfo> pageData = userRepo.findAll(pageRequest);

		List<UserInfo> usersList = pageData.getContent();

		usersList.forEach(System.out::println);

	}

	public void getUsersWithQBE() {

		UserInfo user = new UserInfo();

		Example<UserInfo> of = Example.of(user);
		
		List<UserInfo> all = userRepo.findAll(of);

		all.forEach(System.out::println);

	}

	public void deleteUser() {

		UserInfo info = new UserInfo();
		info.setId(103);
		info.setName("Steve");
		info.setGender("Male");
		info.setAge(25);
		info.setCountry("UK");

		userRepo.delete(info);

		System.out.println("User d...");

	}

	public void getUsersByCountry(String country) {
		List<UserInfo> byCountry = userRepo.findByCountry(country);
		byCountry.forEach(System.out::println);

	}

	public void invokeCustomQueries() {
		List<UserInfo> sqlData = userRepo.getData();
		sqlData.forEach(System.out::println);

		List<UserInfo> hqlData = userRepo.getData1();
		hqlData.forEach(System.out::println);

	}

	public void deleteUserWithCustomQuery(Integer userId) {
		userRepo.deleteUser(userId);
	}

}
